[server]
bind = "0.0.0.0:3000"
session_secret = "change-me-use-a-long-random-string"
db_path = "office_claude.db"
# claude_path = "/home/william/.local/bin/claude"  # set if claude is not in PATH

[session]
idle_timeout_minutes = 30
git_sync_interval_minutes = 15
# sessions_dir = "/var/lib/office_claude/sessions"  # defaults to /tmp (RAM on most Linux systems)

[bootstrap]
username = "admin"
password = "changeme"

[[codebases]]
name = "My Project"
path = "/home/user/code/my-project/"

[[codebases]]
name = "Another Project"
path = "/home/user/code/another-project/"
